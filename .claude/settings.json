{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let s='';process.stdin.on('data',c=>s+=c);process.stdin.on('end',()=>{const d=JSON.parse(s);const p=(d.tool_input&&d.tool_input.file_path)||'';const blocked=['.env','.ssh','secret','credentials'];if(blocked.some(b=>p.includes(b))){process.stderr.write('Acces bloque : fichier sensible -> '+p+'\\n');process.exit(2);}process.exit(0);})\""
          }
        ]
      }
    ]
  }
}
